generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ProductStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum OrderStatus {
  PENDING
  PAID
  PAYMENT_FAILED
  EXPIRED
  FULFILLED
  CANCELED
  REFUNDED
}

enum InventoryMovementType {
  SALE
  ADJUSTMENT
  RESTOCK
  RESERVATION
  RELEASE
}

enum OrderInventoryStatus {
  OK
  SHORT
}

enum NotificationChannel {
  FEISHU
}

enum NotificationStatus {
  PENDING
  SENT
  FAILED
}

enum AdminRoleName {
  SUPER_ADMIN
  ADMIN
  OPERATOR
  CONTENT_EDITOR
  ANALYST
  VIEWER
}

enum ContentType {
  GUIDE
  FAQ
  COLLECTION_PAGE
  STATIC_PAGE
}

enum ContentStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum FulfillmentStatus {
  UNFULFILLED
  FULFILLED
}

enum RuleSetStatus {
  DRAFT
  STAGING
  ACTIVE
  ARCHIVED
}

enum TaxMode {
  EXCLUSIVE
  INCLUSIVE
}

enum ShippingFeeMode {
  FLAT
  FREE_OVER_THRESHOLD
}

enum PaymentMethodCode {
  CARD
  APPLE_PAY
  GOOGLE_PAY
  PAYPAL
  BNPL
}

enum SeoPageType {
  HOME
  PRODUCT
  COLLECTION
  GUIDE
  FAQ
  LANDING
}

enum SeoIssueStatus {
  OPEN
  REVIEWED
  ACCEPTED
  REJECTED
  RESOLVED
}

enum SeoRecommendationStatus {
  DRAFT
  REVIEWED
  APPLIED
  REJECTED
}

enum ContentOpportunityStatus {
  NEW
  REVIEWED
  ACCEPTED
  REJECTED
  DONE
}

enum ContentPipelineStatus {
  OPPORTUNITY
  BRIEF_GENERATED
  DRAFT_GENERATED
  NEEDS_REVIEW
  APPROVED
  PUBLISHED
  MONITORING
}

enum InternalLinkSuggestionStatus {
  NEW
  ACCEPTED
  REJECTED
  APPLIED
}

enum GeoPlatform {
  CHATGPT
  PERPLEXITY
  GEMINI
  GOOGLE_AI_OVERVIEW
}

enum GeoRecommendationStatus {
  DRAFT
  REVIEWED
  APPLIED
}

enum ProductCandidateSource {
  MANUAL
  AI_GENERATED
  CSV
  ALIBABA_LINK
  SUPPLIER_QUOTE
}

enum ProductCandidateStatus {
  NEW
  RESEARCHING
  WATCH
  SAMPLE
  TEST
  APPROVED
  REJECTED
  HIGH_RISK_REVIEW
}

enum ProductResearchRecommendedAction {
  SAMPLE
  TEST
  WATCH
  REJECT
  REVIEW
  APPROVE
}

enum SupplierPlatform {
  ALIBABA
  ALIEXPRESS
  CJ_DROPSHIPPING
  AGENT
  OTHER
}

enum ProductResearchSignalSource {
  GOOGLE_TRENDS
  GSC
  GA4
  AMAZON
  ETSY
  TIKTOK
  ALIBABA
  MANUAL
}

enum ProductTestLaunchStatus {
  PLANNED
  RUNNING
  COMPLETED
  STOPPED
}

enum ProductResearchDecisionType {
  SAMPLE
  TEST
  WATCH
  APPROVE
  REJECT
  CONVERT_TO_PRODUCT
}

enum ProductResearchImportSource {
  AI
  CSV
  ALIBABA_LINK
  SUPPLIER_QUOTE
  MANUAL
}

enum ProductResearchRiskSeverity {
  LOW
  MEDIUM
  HIGH
  BLOCKING
}

model Product {
    id               String              @id @default(cuid())
    title            String
    titleEn          String?
    titleZh          String?
    slug             String              @unique
    category         String
    shortDescription String
    shortDescriptionEn String?
    shortDescriptionZh String?
    description      String
    descriptionEn    String?
    descriptionZh    String?
    seoTitle         String?
    seoTitleEn       String?
    seoTitleZh       String?
    seoDescription   String?
    seoDescriptionEn String?
    seoDescriptionZh String?
    canonicalUrl     String?
    ogImageUrl       String?
    status           ProductStatus       @default(ACTIVE)
    badge            String?
    rating           Decimal             @default(0) @db.Decimal(2, 1)
    reviewCount      Int                 @default(0)
    benefits         String[]
    benefitsEn       String[]            @default([])
    benefitsZh       String[]            @default([])
    features         String[]
    featuresEn       String[]            @default([])
    featuresZh       String[]            @default([])
    useCases         String[]
  bundleEligible   Boolean             @default(false)
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  images           ProductImage[]
  variants         ProductVariant[]
  collections      ProductCollection[]
  orderItems       OrderItem[]
  convertedFromCandidates ProductCandidate[] @relation("ConvertedProduct")
}

model AdminUser {
  id            String      @id @default(cuid())
  email         String      @unique
  passwordHash  String
  name          String
  active        Boolean     @default(true)
  lastLoginAt   DateTime?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  roleId        String
  role          AdminRole   @relation(fields: [roleId], references: [id])
  auditLogs     AuditLog[]
  orderNotes    OrderNote[]
  orderStatusEvents OrderStatusEvent[]
  seoChangeLogs SeoChangeLog[]
  createdProductCandidates ProductCandidate[] @relation("ProductCandidateCreatedBy")
  approvedProductCandidates ProductCandidate[] @relation("ProductCandidateApprovedBy")
  productResearchImportBatches ProductResearchImportBatch[] @relation("ProductResearchImportBatchCreatedBy")
  productResearchDecisions ProductResearchDecision[] @relation("ProductResearchDecisionOperator")
  createdScoringRules ScoringRule[] @relation("ScoringRuleCreatedBy")
  resolvedRiskFlags   ProductResearchRiskFlag[] @relation("ProductResearchRiskFlagResolvedBy")

  @@index([roleId])
}

model AdminRole {
  id        String         @id @default(cuid())
  name      AdminRoleName  @unique
  label     String
  users     AdminUser[]
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
}

model AuditLog {
  id         String      @id @default(cuid())
  actorId    String?
  action     String
  resource   String
  resourceId String?
  details    Json?
  createdAt  DateTime    @default(now())
  actor      AdminUser?  @relation(fields: [actorId], references: [id], onDelete: SetNull)

  @@index([actorId])
  @@index([resource, resourceId])
  @@index([createdAt])
}

model SeoPage {
  id                   String     @id @default(cuid())
  url                  String     @unique
  pageType             SeoPageType
  title                String?
  metaDescription      String?
  canonicalUrl         String?
  h1Count              Int        @default(0)
  missingAltCount      Int        @default(0)
  inSitemap            Boolean    @default(false)
  isIndexable          Boolean    @default(true)
  hasProductJsonLd     Boolean    @default(false)
  hasBreadcrumbJsonLd  Boolean    @default(false)
  healthScore          Int        @default(100)
  lastCheckedAt        DateTime?
  createdAt            DateTime   @default(now())
  updatedAt            DateTime   @updatedAt
  issues               SeoIssue[]
  recommendations      SeoRecommendation[]

  @@index([pageType])
  @@index([healthScore])
}

model SeoIssue {
  id           String         @id @default(cuid())
  seoPageId     String
  issueType     String
  severity      String
  message       String
  status        SeoIssueStatus @default(OPEN)
  metadata      Json?
  detectedAt    DateTime      @default(now())
  resolvedAt    DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  seoPage       SeoPage       @relation(fields: [seoPageId], references: [id], onDelete: Cascade)

  @@index([seoPageId, status])
  @@index([issueType, severity])
}

model SeoRecommendation {
  id             String                  @id @default(cuid())
  seoPageId      String?
  recommendationType String
  resourceType   String
  resourceId     String?
  draftPayload   Json
  reason         String
  priority       String
  status         SeoRecommendationStatus @default(DRAFT)
  isAiDraft      Boolean                 @default(true)
  createdAt      DateTime                @default(now())
  updatedAt      DateTime                @updatedAt
  appliedAt      DateTime?
  seoPage        SeoPage?                @relation(fields: [seoPageId], references: [id], onDelete: SetNull)

  @@index([status, priority])
  @@index([resourceType, resourceId])
}

model SearchConsoleQueryDaily {
  id          String   @id @default(cuid())
  siteUrl     String
  page        String
  query       String
  country     String
  device      String
  date        DateTime
  clicks      Int
  impressions Int
  ctr         Decimal  @db.Decimal(5, 4)
  position    Decimal  @db.Decimal(6, 2)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([siteUrl, date, query, page, country, device])
  @@index([page, date])
}

model SearchConsolePageDaily {
  id          String   @id @default(cuid())
  siteUrl     String
  page        String
  country     String
  device      String
  date        DateTime
  clicks      Int
  impressions Int
  ctr         Decimal  @db.Decimal(5, 4)
  position    Decimal  @db.Decimal(6, 2)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([siteUrl, date, page, country, device])
  @@index([page, date])
}

model Ga4LandingPageDaily {
  id            String   @id @default(cuid())
  landingPage   String
  sourceMedium  String
  date          DateTime
  sessions      Int
  totalUsers    Int
  pageViews     Int
  viewItem      Int
  addToCart     Int
  beginCheckout Int
  purchase      Int
  revenue       Decimal  @db.Decimal(12, 2)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([landingPage, sourceMedium, date])
  @@index([landingPage, date])
}

model ContentOpportunity {
  id              String                   @id @default(cuid())
  opportunityType String
  keyword         String?
  currentPage     String?
  suggestedAction String
  priority        String
  expectedImpact  String
  status          ContentOpportunityStatus @default(NEW)
  metadata        Json?
  createdAt       DateTime                 @default(now())
  updatedAt       DateTime                 @updatedAt
  contentBriefs   ContentBrief[]

  @@index([status, priority])
  @@index([opportunityType])
}

model ContentBrief {
  id                  String                @id @default(cuid())
  sourceOpportunityId String?
  title               String
  targetKeyword       String
  outline             Json?
  draftContent        String?
  relatedProductIds   String[]
  relatedCollectionSlugs String[]
  status              ContentPipelineStatus @default(OPPORTUNITY)
  publishedContentEntryId String?
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt
  sourceOpportunity   ContentOpportunity?   @relation(fields: [sourceOpportunityId], references: [id], onDelete: SetNull)

  @@index([status])
}

model InternalLinkSuggestion {
  id          String                       @id @default(cuid())
  sourcePage  String
  targetPage  String
  anchorText  String
  reason      String
  priority    String
  status      InternalLinkSuggestionStatus @default(NEW)
  metadata    Json?
  createdAt   DateTime                     @default(now())
  updatedAt   DateTime                     @updatedAt

  @@index([status, priority])
}

model GeoPrompt {
  id          String       @id @default(cuid())
  prompt      String       @unique
  isActive    Boolean      @default(true)
  createdById String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  testRuns    GeoTestRun[]

  @@index([isActive, createdAt])
}

model GeoTestRun {
  id                        String          @id @default(cuid())
  platform                  GeoPlatform
  promptId                  String?
  promptText                String
  notes                     String?
  whetherPulseGearMentioned Boolean         @default(false)
  whetherPulseGearCited     Boolean         @default(false)
  actorId                   String?
  createdAt                 DateTime        @default(now())
  prompt                    GeoPrompt?      @relation(fields: [promptId], references: [id], onDelete: SetNull)
  citations                 GeoCitation[]
  mentions                  GeoMention[]
  competitors               GeoCompetitor[]

  @@index([platform, createdAt])
  @@index([promptId, createdAt])
}

model GeoCitation {
  id        String     @id @default(cuid())
  runId     String
  url       String
  title     String?
  createdAt DateTime   @default(now())
  run       GeoTestRun @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@index([runId])
}

model GeoMention {
  id        String     @id @default(cuid())
  runId     String
  brand     String
  isPulse   Boolean    @default(false)
  createdAt DateTime   @default(now())
  run       GeoTestRun @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@index([runId, isPulse])
}

model GeoCompetitor {
  id        String     @id @default(cuid())
  runId     String
  brand     String
  createdAt DateTime   @default(now())
  run       GeoTestRun @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@index([runId])
}

model GeoRecommendation {
  id              String                  @id @default(cuid())
  query           String?
  pagePath        String?
  recommendation  String
  recommendationType String
  priority        String                  @default("MEDIUM")
  status          GeoRecommendationStatus @default(DRAFT)
  createdById     String?
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt

  @@index([status, priority])
}

model GeoContentDraft {
  id          String      @id @default(cuid())
  title       String
  slug        String      @unique
  contentType String
  status      ContentStatus @default(DRAFT)
  source      String?
  payload     Json
  createdById String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@index([contentType, status, createdAt])
}

model SeoChangeLog {
  id          String     @id @default(cuid())
  action      String
  resourceType String
  resourceId  String?
  oldValue    Json?
  newValue    Json?
  operatorId  String?
  createdAt   DateTime   @default(now())
  operator    AdminUser? @relation(fields: [operatorId], references: [id], onDelete: SetNull)

  @@index([resourceType, resourceId])
  @@index([operatorId, createdAt])
}

model ProductCandidate {
  id                 String                           @id @default(cuid())
  productName        String
  chineseName        String?
  slugSuggestion     String?
  category           String
  targetMarket       String
  targetAudience     String?
  useCase            String?
  description        String?
  notes              String?
  brandAngle         String?
  positioningSummary String?
  alibabaKeywords    String?
  source             ProductCandidateSource
  sourceUrl          String?
  rawImportData      Json?
  aiDraftPayload     Json?
  status             ProductCandidateStatus          @default(NEW)
  recommendedAction  ProductResearchRecommendedAction @default(WATCH)
  finalScore         Float?
  riskScore          Int?
  validatedScore     Float?
  possibleDuplicateOfId String?
  createdById        String?
  approvedById       String?
  approvedAt         DateTime?
  convertedProductId String?
  createdAt          DateTime                         @default(now())
  updatedAt          DateTime                         @updatedAt
  possibleDuplicateOf ProductCandidate?              @relation("CandidatePossibleDuplicate", fields: [possibleDuplicateOfId], references: [id], onDelete: SetNull)
  duplicateCandidates ProductCandidate[]             @relation("CandidatePossibleDuplicate")
  createdBy          AdminUser?                      @relation("ProductCandidateCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  approvedBy         AdminUser?                      @relation("ProductCandidateApprovedBy", fields: [approvedById], references: [id], onDelete: SetNull)
  convertedProduct   Product?                        @relation("ConvertedProduct", fields: [convertedProductId], references: [id], onDelete: SetNull)
  scores             ProductCandidateScore[]
  suppliers          ProductCandidateSupplier[]
  signals            ProductResearchSignal[]
  testLaunches       ProductTestLaunch[]
  decisions          ProductResearchDecision[]
  riskFlags          ProductResearchRiskFlag[]

  @@index([status, updatedAt])
  @@index([source, createdAt])
  @@index([targetMarket, category])
  @@index([productName])
  @@index([productName, category, targetMarket])
  @@index([recommendedAction])
  @@index([finalScore])
  @@index([riskScore])
  @@index([possibleDuplicateOfId])
  @@index([createdById])
  @@index([approvedById])
}

model ProductCandidateScore {
  id                      String            @id @default(cuid())
  candidateId             String
  marketDemandScore       Int
  trendSeasonalityScore   Int
  competitionGapScore     Int
  marginPotentialScore    Int
  logisticsFitScore       Int
  brandabilityScore       Int
  supplierQualityScore    Int
  riskScore               Int
  riskInverseScore        Int
  testabilityScore        Int
  finalScore              Float
  scoringVersion          String
  scoreReasonJson         Json?
  isManualAdjusted        Boolean           @default(false)
  manualAdjustmentReason  String?
  createdAt               DateTime          @default(now())
  computedAt              DateTime          @default(now())
  candidate               ProductCandidate  @relation(fields: [candidateId], references: [id], onDelete: Cascade)

  @@index([candidateId, createdAt])
  @@index([scoringVersion])
}

model Supplier {
  id                    String                     @id @default(cuid())
  platform              SupplierPlatform
  name                  String
  url                   String?
  country               String?
  verifiedSupplier      Boolean                    @default(false)
  tradeAssurance        Boolean                    @default(false)
  yearsOnPlatform       Int?
  responseRate          Float?
  moq                   Int?
  samplePriceCents      Int?
  unitPriceCents        Int?
  customLogoMoq         Int?
  customPackagingMoq    Int?
  leadTimeDays          Int?
  shippingToUSCents     Int?
  shippingToUKCents     Int?
  certifications        String[]                  @default([])
  notes                 String?
  createdAt             DateTime                   @default(now())
  updatedAt             DateTime                   @updatedAt
  productCandidates     ProductCandidateSupplier[]

  @@index([platform, country])
  @@index([verifiedSupplier, tradeAssurance])
  @@index([name])
  @@index([url])
}

model ProductCandidateSupplier {
  candidateId            String
  supplierId             String
  quotedUnitPriceCents   Int?
  quotedMoq              Int?
  quotedLeadTimeDays     Int?
  quoteFileUrl           String?
  notes                  String?
  candidate              ProductCandidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  supplier               Supplier         @relation(fields: [supplierId], references: [id], onDelete: Cascade)

  @@id([candidateId, supplierId])
  @@index([supplierId])
}

model ProductResearchSignal {
  id           String                      @id @default(cuid())
  candidateId  String
  source       ProductResearchSignalSource
  metricName   String
  metricValue  Float
  rawData      Json?
  collectedAt  DateTime
  candidate    ProductCandidate            @relation(fields: [candidateId], references: [id], onDelete: Cascade)

  @@index([candidateId, source])
  @@index([metricName, collectedAt])
}

model ProductTestLaunch {
  id                    String                   @id @default(cuid())
  candidateId           String
  landingPageUrl        String?
  channel               String
  channelDetail         String?
  adSpendCents          Int                      @default(0)
  impressions           Int                      @default(0)
  clicks                Int                      @default(0)
  ctr                   Float                    @default(0)
  productViews          Int                      @default(0)
  addToCart             Int                      @default(0)
  addToCartRate         Float                    @default(0)
  beginCheckout         Int                      @default(0)
  checkoutRate          Float                    @default(0)
  purchases             Int                      @default(0)
  purchaseRate          Float                    @default(0)
  revenueCents          Int                      @default(0)
  refunds               Int                      @default(0)
  customerFeedbackScore Int?
  refundRiskScore       Int?
  customerFeedbackSummary String?
  notes                 String?
  testScore             Float?
  status                ProductTestLaunchStatus  @default(PLANNED)
  startedAt             DateTime?
  endedAt               DateTime?
  createdAt             DateTime                 @default(now())
  updatedAt             DateTime                 @updatedAt
  candidate             ProductCandidate         @relation(fields: [candidateId], references: [id], onDelete: Cascade)

  @@index([candidateId, status])
  @@index([status, startedAt])
}

model ProductResearchDecision {
  id          String                      @id @default(cuid())
  candidateId String
  decision    ProductResearchDecisionType
  reason      String?
  operatorId  String?
  createdAt   DateTime                    @default(now())
  candidate   ProductCandidate            @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  operator    AdminUser?                  @relation("ProductResearchDecisionOperator", fields: [operatorId], references: [id], onDelete: SetNull)

  @@index([candidateId, createdAt])
  @@index([operatorId, createdAt])
  @@index([decision, createdAt])
}

model ProductResearchImportBatch {
  id             String                      @id @default(cuid())
  source         ProductResearchImportSource
  fileName       String?
  totalRows      Int                         @default(0)
  createdCount   Int                         @default(0)
  skippedCount   Int                         @default(0)
  duplicateCount Int                         @default(0)
  invalidCount   Int                         @default(0)
  createdById    String?
  createdAt      DateTime                    @default(now())
  createdBy      AdminUser?                  @relation("ProductResearchImportBatchCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([source, createdAt])
  @@index([createdById, createdAt])
}

model ProductResearchRiskFlag {
  id             String                       @id @default(cuid())
  candidateId    String
  riskType       String
  severity       ProductResearchRiskSeverity
  message        String
  resolvedAt     DateTime?
  resolvedById   String?
  resolutionNote String?
  createdAt      DateTime                     @default(now())
  candidate      ProductCandidate             @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  resolvedBy       AdminUser?                   @relation("ProductResearchRiskFlagResolvedBy", fields: [resolvedById], references: [id], onDelete: SetNull)

  @@index([candidateId, severity])
  @@index([candidateId, resolvedAt])
  @@index([severity, createdAt])
}

model ScoringRule {
  id         String      @id @default(cuid())
  version    String      @unique
  weights    Json
  isActive   Boolean     @default(false)
  createdById String?
  createdAt  DateTime    @default(now())
  createdBy  AdminUser?  @relation("ScoringRuleCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([isActive, createdAt])
  @@index([createdById])
}

model AdminSettings {
  id                              String   @id
  storefrontUrl                   String
  supportEmail                    String
  checkoutCurrency                String   @default("usd")
  timezone                        String   @default("America/Los_Angeles")
  shippingCountries               String[]
  defaultFulfillmentSlaDays       Int      @default(3)
  returnsPolicyUrl                String?
  orderAutoFulfill                Boolean  @default(false)
  primaryPaymentProvider          String   @default("Stripe Checkout")
  stripeAutomaticPaymentMethods   Boolean  @default(true)
  paymentFailureMessage           String?
  adminSessionTtlHours            Int      @default(12)
  auditLoggingEnabled             Boolean  @default(true)
  createdAt                       DateTime @default(now())
  updatedAt                       DateTime @updatedAt
}

model SiteSetting {
  key       String   @id
  value     Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model UiCopy {
  key       String
  locale    String   @default("en-US")
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@id([key, locale])
}

model ContentTemplate {
  key       String
  locale    String   @default("en-US")
  name      String
  content   Json
  status    String   @default("ACTIVE")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@id([key, locale])
}

model SeoAutomationRule {
  key       String   @id
  value     Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ContentEntry {
    id                     String                   @id @default(cuid())
    type                   ContentType
    title                  String
    titleEn                String?
    titleZh                String?
    slug                   String
    status                 ContentStatus            @default(DRAFT)
    seoTitle               String?
    seoTitleEn             String?
    seoTitleZh             String?
    seoDescription         String?
    seoDescriptionEn       String?
    seoDescriptionZh       String?
    publishedAt            DateTime?
  createdAt              DateTime                 @default(now())
  updatedAt              DateTime                 @updatedAt
  guideContent           GuideContent?
  faqContent             FaqContent?
  collectionLandingContent CollectionLandingContent?
  staticPageContent      StaticPageContent?

  @@unique([type, slug])
  @@index([type, status])
}

model GuideContent {
    entryId             String       @id
    dek                 String
    dekEn               String?
    dekZh               String?
    category            String
    categoryEn          String?
    categoryZh          String?
    authorName          String
    authorRole          String
    authorRoleEn        String?
    authorRoleZh        String?
    readTime            String
    readTimeEn          String?
    readTimeZh          String?
    sections            Json
    sectionsEn          Json?
    sectionsZh          Json?
    faq                 Json
    faqEn               Json?
    faqZh               Json?
    relatedProducts     Json
    relatedCollections  Json
    relatedGuides       Json
  entry               ContentEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)
}

model FaqContent {
    entryId  String       @id
    items    Json
    itemsEn  Json?
    itemsZh  Json?
    entry    ContentEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)
}

model CollectionLandingContent {
    entryId            String       @id
    pathname           String       @unique
    scenario           String?
    intro              String?
    introEn            String?
    introZh            String?
    category           String?
    useCase            String?
    relatedGuideSlugs  Json
    entry              ContentEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)
  }

model StaticPageContent {
    entryId            String       @id
    pageKey            String       @unique
    pathname           String       @unique
    content            Json
    contentEn          Json?
    contentZh          Json?
    entry              ContentEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)
}

model ProductVariant {
  id                    String              @id @default(cuid())
  productId             String
  sku                   String              @unique
  color                 String
  size                  String
  priceCents            Int
  compareAtPriceCents   Int?
  stock                 Int                 @default(0)
  reservedStock         Int                 @default(0)
  lowStockThreshold     Int                 @default(5)
  weightGrams           Int?
  active                Boolean             @default(true)
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt
  product               Product             @relation(fields: [productId], references: [id], onDelete: Cascade)
  orderItems            OrderItem[]
  inventoryMovements    InventoryMovement[]

  @@index([productId])
  @@index([color, size])
}

model ProductImage {
  id        String   @id @default(cuid())
  productId String
  url       String
  alt       String
  sortOrder Int      @default(0)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
}

model Collection {
  id          String              @id @default(cuid())
  title       String
  slug        String              @unique
  description String?
  sortOrder   Int                 @default(0)
  products    ProductCollection[]
}

model ProductCollection {
  productId    String
  collectionId String
  sortOrder    Int        @default(0)
  product      Product    @relation(fields: [productId], references: [id], onDelete: Cascade)
  collection   Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)

  @@id([productId, collectionId])
  @@index([collectionId])
}

model Order {
  id                      String      @id @default(cuid())
  orderNo                 String      @unique
  email                   String?
  status                  OrderStatus @default(PENDING)
  currency                String      @default("usd")
  subtotalCents           Int
  shippingCents           Int
  discountCents           Int         @default(0)
  totalCents              Int
  stripeCheckoutSessionId String?     @unique
  stripePaymentIntentId   String?
  paymentMethodType       String?
  paymentStatus           PaymentStatus           @default(PENDING)
  inventoryStatus         OrderInventoryStatus    @default(OK)
  fulfillmentStatus       FulfillmentStatus       @default(UNFULFILLED)
  fulfilledAt             DateTime?
  customerCountry         String?
  shippingAddress         Json?
  billingAddress          Json?
  ruleSetVersion          Int?
  pricingSnapshot         Json?
  createdAt               DateTime    @default(now())
  updatedAt               DateTime    @updatedAt
  items                   OrderItem[]
  paymentEvents           PaymentEvent[]
  inventoryMovements      InventoryMovement[]
  notes                   OrderNote[]
  statusEvents            OrderStatusEvent[]

  @@index([status])
  @@index([stripePaymentIntentId])
  @@index([paymentStatus, fulfillmentStatus])
}

model CommerceRuleSet {
  id                String        @id @default(cuid())
  name              String
  version           Int
  status            RuleSetStatus @default(DRAFT)
  description       String?
  effectiveFrom     DateTime?
  effectiveTo       DateTime?
  createdByAdminId  String?
  publishedByAdminId String?
  publishedAt       DateTime?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  taxRules          TaxRule[]
  shippingRules     ShippingRule[]
  paymentRules      PaymentMethodRule[]

  @@unique([version])
  @@index([status, effectiveFrom, effectiveTo])
}

model TaxRule {
  id                String          @id @default(cuid())
  ruleSetId         String
  countryCode       String
  regionCode        String?
  postalCodePattern String?
  currency          String
  taxMode           TaxMode         @default(EXCLUSIVE)
  rateBps           Int
  priority          Int             @default(100)
  enabled           Boolean         @default(true)
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  ruleSet           CommerceRuleSet @relation(fields: [ruleSetId], references: [id], onDelete: Cascade)

  @@index([ruleSetId, countryCode, regionCode, currency, priority])
}

model ShippingRule {
  id              String          @id @default(cuid())
  ruleSetId       String
  countryCode     String
  regionCode      String?
  currency        String
  feeMode         ShippingFeeMode
  flatFeeMinor    Int?
  freeOverMinor   Int?
  priority        Int             @default(100)
  enabled         Boolean         @default(true)
  etaMinDays      Int?
  etaMaxDays      Int?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  ruleSet         CommerceRuleSet @relation(fields: [ruleSetId], references: [id], onDelete: Cascade)

  @@index([ruleSetId, countryCode, regionCode, currency, priority])
}

model PaymentMethodRule {
  id             String            @id @default(cuid())
  ruleSetId      String
  countryCode    String
  currency       String
  method         PaymentMethodCode
  minAmountMinor Int?
  maxAmountMinor Int?
  enabled        Boolean           @default(true)
  priority       Int               @default(100)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  ruleSet        CommerceRuleSet   @relation(fields: [ruleSetId], references: [id], onDelete: Cascade)

  @@index([ruleSetId, countryCode, currency, method, priority])
}

model OrderNote {
  id               String    @id @default(cuid())
  orderId          String
  note             String
  createdByAdminId String?
  createdAt        DateTime  @default(now())
  order            Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  createdByAdmin   AdminUser? @relation(fields: [createdByAdminId], references: [id], onDelete: SetNull)

  @@index([orderId, createdAt])
  @@index([createdByAdminId])
}

model OrderStatusEvent {
  id               String    @id @default(cuid())
  orderId          String
  type             String
  fromValue        String?
  toValue          String?
  details          Json?
  createdByAdminId String?
  createdAt        DateTime  @default(now())
  order            Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  createdByAdmin   AdminUser? @relation(fields: [createdByAdminId], references: [id], onDelete: SetNull)

  @@index([orderId, createdAt])
  @@index([createdByAdminId])
}

model OrderItem {
  id              String         @id @default(cuid())
  orderId         String
  productId       String
  variantId       String
  titleSnapshot   String
  skuSnapshot     String
  colorSnapshot   String
  sizeSnapshot    String
  quantity        Int
  unitPriceCents  Int
  lineTotalCents  Int
  order           Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product         Product        @relation(fields: [productId], references: [id])
  variant         ProductVariant @relation(fields: [variantId], references: [id])

  @@index([orderId])
  @@index([variantId])
}

model PaymentEvent {
  id             String   @id @default(cuid())
  stripeEventId  String   @unique
  type           String
  orderId        String?
  payload        Json
  processedAt    DateTime @default(now())
  order          Order?   @relation(fields: [orderId], references: [id])
}

model InventoryMovement {
  id          String                @id @default(cuid())
  variantId   String
  orderId     String?
  type        InventoryMovementType
  quantity    Int
  reason      String
  createdAt   DateTime              @default(now())
  variant     ProductVariant        @relation(fields: [variantId], references: [id])
  order       Order?                @relation(fields: [orderId], references: [id])

  @@unique([orderId, variantId, type])
  @@index([variantId])
  @@index([orderId])
}

model NotificationOutbox {
  id           String              @id @default(cuid())
  channel      NotificationChannel
  type         String
  dedupeKey    String?             @unique
  payload      Json
  status       NotificationStatus  @default(PENDING)
  attempts     Int                 @default(0)
  lastError    String?
  nextRetryAt  DateTime            @default(now())
  sentAt       DateTime?
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  @@index([status, nextRetryAt])
  @@index([createdAt])
}
