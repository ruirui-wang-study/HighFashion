{
  "name": "pulsegear-storefront",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:api": "npm --prefix api run start:dev",
    "dev:all": "concurrently \"npm run dev\" \"npm run dev:api\"",
    "build": "next build",
    "build:api": "npm --prefix api run build",
    "start": "next start",
    "lint": "eslint .",
    "lint:api": "npm --prefix api run lint",
    "test:api": "npm --prefix api test",
    "db:migrate": "npm --prefix api run prisma:migrate",
    "db:seed": "npm --prefix api run prisma:seed"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.6",
    "@radix-ui/react-slot": "^1.1.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.468.0",
    "next": "^16.2.6",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "tailwind-merge": "^2.6.0",
    "tailwindcss-animate": "^1.0.7"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@types/node": "^22.10.5",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.6",
    "postcss": "^8.5.10",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2",
    "concurrently": "^9.2.1"
  }
}
